<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon (Android 8.0+, API 26).
  Without this, Android wraps the legacy PNG in its default white container
  in surfaces like Settings → Apps and the Recents screen — producing the
  "small icon centered in a white circle" appearance. With adaptive icons,
  the system masks the foreground directly using the launcher's own icon
  shape (circle, squircle, rounded-square, etc.).
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
